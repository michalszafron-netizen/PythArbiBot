# Copy to .env and fill in your values
# NEVER commit .env to git

# Arbitrum RPC endpoint (HTTP)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Arbitrum RPC endpoint (WebSocket) - optional, for event subscriptions
ARBITRUM_WS_URL=

# Private key for transaction signing - DO NOT use a wallet with significant funds yet
# Generate fresh with: python -c "from eth_account import Account; print(Account.create().key.hex())"
PRIVATE_KEY=

# Pyth Hermes endpoints (defaults are fine)
PYTH_HERMES_HTTP=https://hermes.pyth.network
PYTH_HERMES_WS=wss://hermes.pyth.network/ws

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
